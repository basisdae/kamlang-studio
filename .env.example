# Business Insight — Supabase (kn-queue)
# Copy to .env.local — never commit real values
#
# URL = Project URL only (Settings → API)
# Example: https://xxxx.supabase.co
# Do NOT append /rest/v1 — causes "Invalid path specified in request URL"

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional
NEXT_PUBLIC_APP_URL=http://localhost:3000
